rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {

      // Any authenticated user can read their own document
      allow read: if request.auth != null && request.auth.uid == userId;

      // New user sign-up: allow creating own doc (sets plan: "free", initial credits)
      allow create: if request.auth != null && request.auth.uid == userId;

      // Updates: authenticated user can only modify safe fields.
      // 'credits', 'plan', and 'upgradedAt' are server-only — only the
      // backend Admin SDK can touch those fields.
      allow update: if request.auth != null
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['credits', 'plan', 'upgradedAt']);
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
